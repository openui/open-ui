---
import staticContributors from '../data/contributors.json';

const CONTRIBUTORS_URL = 'https://api.github.com/repos/openui/open-ui/contributors';
const pages = [1, 2];
const CONTRIBUTORS = [...staticContributors];

const responses = await Promise.allSettled(
  pages.map((page) =>
    fetch(`${CONTRIBUTORS_URL}?page=${page}`, {
      headers: {
        Accept: 'application/vnd.github+json',
      },
    }),
  ),
);

for (const result of responses) {
  if (result.status !== 'fulfilled' || !result.value.ok) {
    continue;
  }

  const contributors = await result.value.json().catch(() => null);
  if (Array.isArray(contributors)) {
    CONTRIBUTORS.push(...contributors);
  }
}

const contributorsByLogin = new Map(
  CONTRIBUTORS
    .filter((contributor) => contributor?.login && !contributor.login.includes('dependabot'))
    .map((contributor) => [contributor.login, contributor]),
);

const CONTRIBUTORS_SAFE = [...contributorsByLogin.values()];
---

<ul>
  {CONTRIBUTORS_SAFE.map(({ login, avatar_url, html_url }) => (
    <li>
      <a href={html_url} title={login}>
        <img src={avatar_url} alt={`Github user ${login}`} width="48" height="48" loading="lazy"/>
      </a>
    </li>
  ))}
</ul>

<style>
  ul {
    list-style-type: none;
    display: flex;
    flex-wrap: wrap;
  }
  ul, li {
    margin: 0;
  }
  li {
    inline-size: 48px;
    aspect-ratio: 1;
  }
  img {
    border-radius: 50%;
    object-fit: cover;
    scale: 1.2;
    border: 2px solid #007a3d;
    background: #ffffff;
  }
</style>
